{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitelier.dev/schemas/v1/events.schema.json",
  "title": "Event",
  "description": "Streaming event from a task execution",
  "type": "object",
  "required": ["type", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "run.started",
        "run.completed",
        "run.error",
        "provider.started",
        "provider.completed",
        "provider.error",
        "item.delta",
        "item.done"
      ],
      "description": "Event type"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "run_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event-specific payload"
    }
  },
  "additionalProperties": false
}
