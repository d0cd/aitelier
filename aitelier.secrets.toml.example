# aitelier secrets — gitignored when copied to aitelier.secrets.toml.
# Same TOML shape as aitelier.toml. Loaded as an overlay on top of the base
# config (any key here overrides the same key in aitelier.toml).
#
# Use this for anything you don't want checked in: API keys, OAuth tokens,
# webhook secrets.

# [litellm]
# api_key = "sk-litellm-local"   # the proxy's own key, not your provider key

# [service]
# api_key = "..."                # enables hosted-mode Authorization: Bearer
# webhook_secret = "..."         # HMAC for outbound webhook signing

# [sandbox_agent]
# token = "..."                  # for remote sandbox-agent (closed-laptop mode)
